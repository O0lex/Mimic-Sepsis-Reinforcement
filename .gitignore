# Python caches and environments
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
.env

# Notebook artifacts
.ipynb_checkpoints/

# Build and package artifacts
build/
dist/
*.egg-info/

# Runtime logs and outputs
outputs/
d3rlpy_logs/
logs/

# Local scratch artifacts
outsideshit/
report/pastresults.txt

# Generated report figures not currently part of tracked report set
report/generated/figures/**/fig5_action_distribution_comparison.png

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local datasets and large files
# Keep lightweight docs in data/, but ignore raw data payloads by default.
data/*
!data/.gitkeep
!data/README.md

# Public demo dataset is allowed for reproducible examples.
!data/mimic-iv-clinical-database-demo-on-fhir-2.0/
!data/mimic-iv-clinical-database-demo-on-fhir-2.0/**

# Keep any non-demo MIMIC exports private/offline.
data/mimic-iv-clinical-database-*/
!data/mimic-iv-clinical-database-demo-on-fhir-2.0/
!data/mimic-iv-clinical-database-demo-on-fhir-2.0/**
data/mimic-iv-*/
data/private*/


*.parquet
*.npz

# LaTeX auxiliary files
*.aux
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz

